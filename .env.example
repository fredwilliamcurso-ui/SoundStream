# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Custom Domain Configuration
# Set to https://soundstreamy.com or https://www.soundstreamy.com for production builds
VITE_APP_URL="https://soundstreamy.com"

# Supabase Storage Configuration & Auth Redirects
VITE_SUPABASE_URL="https://uxvmdnlpvnjfekqxchfi.supabase.co"
VITE_SUPABASE_ANON_KEY=""
# Optional redirect override for Supabase OAuth/Authentication flows
VITE_SUPABASE_AUTH_REDIRECT_URL="https://soundstreamy.com/auth/callback"

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET=""

# Firebase Authentication Configuration
# Replace with your production project credentials from the Firebase console (settings/web app config)
# Ensure 'soundstreamy.com' and 'www.soundstreamy.com' are added to the 'Authorized Domains' list
# under Authentication > Settings > Authorized Domains in your Firebase Console.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN="soundstreamy.com"
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Android Release Signing Configuration (Google Play Store)
# Do NOT check actual production passwords into version control.
# Configure these on your build system/CI server or local shell environment.
SOUNDSTREAM_KEYSTORE_PASSWORD="my_keystore_secure_password"
SOUNDSTREAM_KEY_ALIAS="soundstream_alias"
SOUNDSTREAM_KEY_PASSWORD="my_key_secure_password"

# GitHub Personal Access Token (PAT) with "repo" scope to push project files
GITHUB_PAT=""

# TikTok Developer Application Configuration (OAuth 2.0)
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# Stripe Payment Gateway Configuration
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_51TFKl"
STRIPE_SECRET_KEY="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"
STRIPE_WEBHOOK_SECRET=""

# Agora RTC Audio Streaming Configuration
# You can generate your own App ID in your Agora Console (https://console.agora.io/)
# If none is provided, it falls back to a standard sandbox development app ID
VITE_AGORA_APP_ID="6fa882836bdf49f2b84ec8198f1a1d94"



