{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/Soundstream.apk",
        "destination": "https://drive.google.com/uc?export=download&id=1SPqh9sOUfMUU801udi-t4cUqvJmQpQsW",
        "type": 302
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "soundstreamy",
          "region": "europe-west1"
        }
      },
      {
        "source": "/create-checkout-session",
        "run": {
          "serviceId": "soundstreamy",
          "region": "europe-west1"
        }
      },
      {
        "source": "/verify-payment",
        "run": {
          "serviceId": "soundstreamy",
          "region": "europe-west1"
        }
      },
      {
        "source": "/stripe/webhook",
        "run": {
          "serviceId": "soundstreamy",
          "region": "europe-west1"
        }
      },
      {
        "source": "/wallet/**",
        "run": {
          "serviceId": "soundstreamy",
          "region": "europe-west1"
        }
      },
      {
        "source": "/transactions/**",
        "run": {
          "serviceId": "soundstreamy",
          "region": "europe-west1"
        }
      },
      {
        "source": "/sitemap.xml",
        "run": {
          "serviceId": "soundstreamy",
          "region": "europe-west1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
