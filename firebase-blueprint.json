        "userId": { "type": "string" },
        "songId": { "type": "string" }
      },
      "required": ["userId", "songId"]
    },
    "Follow": {
      "title": "Follow",
      "description": "User following an artist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "artistId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "artistId", "createdAt"]
    },
    "Album": {
      "title": "Album",
