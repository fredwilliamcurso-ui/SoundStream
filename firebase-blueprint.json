        "userId": { "type": "string" },
        "songId": { "type": "string" },
        "playedAt": { "type": "string" }
      },
      "required": ["userId", "songId", "playedAt"]
    },
    "Following": {
      "title": "Following",
      "description": "Creators followed by users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "artistId": { "type": "string" },
        "followedAt": { "type": "string" }
      },
      "required": ["userId", "artistId", "followedAt"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "User feedback or support request ticket",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "category": { "type": "string" },
