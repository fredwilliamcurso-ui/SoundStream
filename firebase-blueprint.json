      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "songId": { "type": "string" },
        "likedAt": { "type": "string" }
      },
      "required": ["userId", "songId", "likedAt"]
    },
    "RecentlyPlayed": {
      "title": "RecentlyPlayed",
