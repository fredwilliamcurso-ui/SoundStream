{
  "entities": {
    "User": {
      "title": "User",
      "description": "SoundStream listener/creator user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Auth UID" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string" },
        "role": { "type": "string", "enum": ["listener", "artist", "admin"] },
        "isSuspended": { "type": "boolean" },
        "tiktokId": { "type": "string", "description": "Linked TikTok Account ID" },
        "tiktokUsername": { "type": "string", "description": "Linked TikTok Username" },
        "tiktokAccessToken": { "type": "string", "description": "TikTok Access Token" },
        "subscription": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["free", "premium"] },
            "expiresAt": { "type": "string" },
            "updatedAt": { "type": "string" }
          },
          "required": ["status"]
        }
      },
      "required": ["uid", "username", "email", "createdAt", "role"]
    },
    "AdLog": {
      "title": "AdLog",
      "description": "Log of an ad event",
      "type": "object",
      "properties": {
        "eventType": { "type": "string" },
        "adUnitId": { "type": "string" },
        "rewardValue": { "type": "number" },
        "timestamp": { "type": "string" },
        "platform": { "type": "string" }
      },
      "required": ["eventType", "adUnitId", "platform"]
    },
    "Artist": {
      "title": "Artist",
      "description": "Artist page metadata details",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "References user UID" },
        "userId": { "type": "string", "description": "References user ID for backwards compatibility" },
        "artistName": { "type": "string" },
        "bio": { "type": "string" },
        "verified": { "type": "boolean" },
        "profilePhoto": { "type": "string" },
        "followersCount": { "type": "number" },
        "createdAt": { "type": "string" },
        "isSuspended": { "type": "boolean" },
        "isFeatured": { "type": "boolean" },
        "tiktokId": { "type": "string", "description": "Linked TikTok Creator Account ID" },
        "tiktokUsername": { "type": "string", "description": "Linked TikTok Creator Username" }
      },
      "required": ["uid", "artistName", "followersCount", "createdAt"]
    },
    "Song": {
      "title": "Song",
      "description": "A single audio track record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "artistId": { "type": "string" },
        "artistName": { "type": "string" },
        "title": { "type": "string" },
        "genre": { "type": "string" },
        "audioUrl": { "type": "string" },
        "coverUrl": { "type": "string" },
        "playCount": { "type": "number" },
        "lyrics": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "isModerated": { "type": "boolean" }
      },
      "required": ["id", "artistId", "artistName", "title", "genre", "audioUrl"]
    },
    "Playlist": {
      "title": "Playlist",
